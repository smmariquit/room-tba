---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db";
import {
  buildingsTable,
  classesTable,
  collegesTable,
  divisionsTable,
  roomsTable,
} from "../../../drizzle/schema";
import { eq } from "drizzle-orm";
import { buildingPath, roomJsonLd, roomPath, slugify } from "../../lib/seo";

export async function getStaticPaths() {
  const rooms = await db
    .select({
      id: roomsTable.id,
      code: roomsTable.room_code,
      directions: roomsTable.directions,
      buildingName: buildingsTable.building_name,
      buildingLat: buildingsTable.lat,
      buildingLon: buildingsTable.lon,
      buildingDirections: buildingsTable.directions,
      collegeName: collegesTable.college_name,
      divisionName: divisionsTable.division_name,
    })
    .from(roomsTable)
    .leftJoin(buildingsTable, eq(buildingsTable.id, roomsTable.building_id))
    .leftJoin(collegesTable, eq(collegesTable.id, roomsTable.college_id))
    .leftJoin(divisionsTable, eq(divisionsTable.id, roomsTable.division_id));

  const classes = await db
    .select({
      roomId: classesTable.room_id,
      courseCode: classesTable.course_code,
      courseTitle: classesTable.course_title,
      section: classesTable.section,
      type: classesTable.type,
      schedule: classesTable.schedule,
    })
    .from(classesTable);

  const classesByRoom = new Map<number, typeof classes>();
  for (const c of classes) {
    const arr = classesByRoom.get(c.roomId) ?? [];
    arr.push(c);
    classesByRoom.set(c.roomId, arr);
  }

  // Deduplicate slugs (keep the first occurrence; warn on collision via building info).
  const seen = new Set<string>();
  const result: ReturnType<typeof buildPath>[] = [];
  function buildPath(room: (typeof rooms)[number]) {
    return {
      params: { slug: slugify(room.code) },
      props: {
        room,
        classes: (classesByRoom.get(room.id) ?? []).sort((a, b) =>
          a.courseCode.localeCompare(b.courseCode),
        ),
      },
    };
  }
  for (const room of rooms) {
    const slug = slugify(room.code);
    if (seen.has(slug)) continue;
    seen.add(slug);
    result.push(buildPath(room));
  }
  return result;
}

const { room, classes } = Astro.props;

const description = room.buildingName
  ? `Class schedule for room ${room.code} in ${room.buildingName} on the UPLB Los Baños campus. ${classes.length} class${classes.length === 1 ? "" : "es"} on file.`
  : `Class schedule for room ${room.code} on the UPLB Los Baños campus. ${classes.length} class${classes.length === 1 ? "" : "es"} on file.`;

const jsonLd = roomJsonLd({
  code: room.code,
  buildingName: room.buildingName,
  buildingLat: room.buildingLat,
  buildingLon: room.buildingLon,
  collegeName: room.collegeName,
  divisionName: room.divisionName,
});

const mapDeepLink = `/?room=${encodeURIComponent(room.code)}`;
---

<Layout
  title={`Room ${room.code}${room.buildingName ? ` · ${room.buildingName}` : ""}`}
  description={description}
  canonical={roomPath(room.code)}
  ogType="article"
  jsonLd={jsonLd}
>
  <main class="page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Room TBA</a>
      <span aria-hidden="true">/</span>
      {
        room.buildingName ? (
          <a href={buildingPath(room.buildingName)}>{room.buildingName}</a>
        ) : (
          <span>Rooms</span>
        )
      }
      <span aria-hidden="true">/</span>
      <span aria-current="page">{room.code}</span>
    </nav>

    <header class="hero">
      <p class="kicker">UPLB · Room</p>
      <h1>{room.code}</h1>
      {
        room.buildingName && (
          <p class="building-link">
            in{" "}
            <a href={buildingPath(room.buildingName)}>{room.buildingName}</a>
          </p>
        )
      }
      {room.directions && <p class="building-desc">{room.directions}</p>}
      <div class="hero-actions">
        <a class="cta primary" href={mapDeepLink}>Open in interactive map</a>
        {
          room.buildingLat && room.buildingLon && (
            <a
              class="cta"
              href={`https://www.google.com/maps?q=${room.buildingLat},${room.buildingLon}`}
              rel="noopener"
              target="_blank"
            >
              Get directions
            </a>
          )
        }
      </div>
    </header>

    <section class="meta-grid">
      <div>
        <dt>Classes</dt>
        <dd>{classes.length}</dd>
      </div>
      {
        room.collegeName && (
          <div>
            <dt>College</dt>
            <dd>{room.collegeName}</dd>
          </div>
        )
      }
      {
        room.divisionName && (
          <div>
            <dt>Division</dt>
            <dd>{room.divisionName}</dd>
          </div>
        )
      }
    </section>

    <section class="classes-section">
      <h2>Class schedule</h2>
      {
        classes.length === 0 ? (
          <p class="empty">No classes scheduled in this room.</p>
        ) : (
          <ul class="class-list">
            {classes.map((c) => (
              <li class="class-row">
                <div class="class-row-head">
                  <span class="course-code">{c.courseCode}</span>
                  <span class="class-type">{c.type}</span>
                </div>
                <div class="course-title">{c.courseTitle}</div>
                <div class="class-meta">
                  <span>Section {c.section}</span>
                  <span class="dot" aria-hidden="true">
                    ·
                  </span>
                  <span>{c.schedule}</span>
                </div>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <footer class="page-footer">
      <a href="/">← Back to Room TBA</a>
    </footer>
  </main>
</Layout>

<style>
  .page {
    max-width: 50rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    color: hsl(0, 0%, 12%);
  }
  .breadcrumbs {
    font-size: 0.8125rem;
    color: hsl(0, 0%, 45%);
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .breadcrumbs a {
    color: hsl(5, 53%, 32%);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    text-decoration: underline;
  }
  .breadcrumbs [aria-current="page"] {
    color: hsl(0, 0%, 30%);
  }
  .hero {
    margin-top: 1.25rem;
  }
  .kicker {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: hsl(5, 53%, 32%);
    font-weight: 600;
    margin: 0;
  }
  .hero h1 {
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    margin: 0.4rem 0 0.25rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .building-link {
    color: hsl(0, 0%, 35%);
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }
  .building-link a {
    color: hsl(5, 53%, 32%);
    text-decoration: none;
    font-weight: 600;
  }
  .building-link a:hover {
    text-decoration: underline;
  }
  .building-desc {
    color: hsl(0, 0%, 35%);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }
  .hero-actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    background-color: white;
    color: hsl(5, 53%, 32%);
    border: 1px solid hsl(5, 30%, 80%);
  }
  .cta:hover {
    background-color: hsl(5, 53%, 97%);
  }
  .cta.primary {
    background-color: hsl(5, 53%, 32%);
    color: white;
    border-color: hsl(5, 53%, 32%);
  }
  .cta.primary:hover {
    background-color: hsl(5, 53%, 26%);
  }

  .meta-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1rem;
    background-color: hsl(0, 0%, 98%);
    border: 1px solid hsl(0, 0%, 92%);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
  }
  .meta-grid dt {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: hsl(0, 0%, 45%);
    margin: 0;
  }
  .meta-grid dd {
    margin: 0.2rem 0 0;
    font-weight: 600;
    color: hsl(0, 0%, 15%);
  }

  .classes-section {
    margin-top: 2rem;
  }
  .classes-section h2 {
    font-size: 1.125rem;
    margin: 0 0 0.75rem;
  }
  .empty {
    color: hsl(0, 0%, 50%);
    font-size: 0.9rem;
  }
  .class-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .class-row {
    background-color: white;
    border: 1px solid hsl(0, 0%, 90%);
    border-radius: 0.625rem;
    padding: 0.75rem 0.875rem;
  }
  .class-row-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .course-code {
    font-weight: 700;
    color: hsl(0, 0%, 12%);
  }
  .class-type {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background-color: hsl(45, 90%, 92%);
    color: hsl(35, 80%, 30%);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .course-title {
    color: hsl(0, 0%, 25%);
    font-size: 0.875rem;
    margin: 0.2rem 0;
  }
  .class-meta {
    font-size: 0.8125rem;
    color: hsl(0, 0%, 40%);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .class-meta .dot {
    color: hsl(0, 0%, 70%);
  }

  .page-footer {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid hsl(0, 0%, 90%);
  }
  .page-footer a {
    color: hsl(5, 53%, 32%);
    text-decoration: none;
    font-weight: 500;
  }
</style>
