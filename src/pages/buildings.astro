---
import Layout from "../layouts/Layout.astro";
import { db } from "../lib/db";
import {
  buildingsTable,
  roomsTable,
} from "../../drizzle/schema";
import { eq } from "drizzle-orm";
import { buildingPath } from "../lib/seo";

const buildings = await db.select().from(buildingsTable);
const rooms = await db
  .select({
    id: roomsTable.id,
    buildingId: roomsTable.building_id,
  })
  .from(roomsTable);

const roomsByBuilding = new Map<number, number>();
for (const r of rooms) {
  if (r.buildingId === null) continue;
  roomsByBuilding.set(r.buildingId, (roomsByBuilding.get(r.buildingId) ?? 0) + 1);
}

const items = buildings
  .map((b) => ({
    name: b.building_name,
    directions: b.directions,
    roomCount: roomsByBuilding.get(b.id) ?? 0,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

const description = `Browse all ${items.length} buildings on the UPLB Los Baños campus tracked by Room TBA.`;
---

<Layout
  title="UPLB buildings"
  description={description}
  canonical="/buildings"
>
  <main class="page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Room TBA</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Buildings</span>
    </nav>
    <header class="hero">
      <p class="kicker">UPLB · Directory</p>
      <h1>Buildings</h1>
      <p class="lede">{description}</p>
      <a class="cta" href="/">Open the interactive map</a>
    </header>
    <ul class="building-grid">
      {
        items.map((b) => (
          <li>
            <a class="building-card" href={buildingPath(b.name)}>
              <span class="bname">{b.name}</span>
              <span class="bmeta">
                {b.roomCount} room{b.roomCount === 1 ? "" : "s"}
              </span>
              {b.directions && <span class="bdesc">{b.directions}</span>}
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  .page {
    max-width: 60rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    color: hsl(0, 0%, 12%);
  }
  .breadcrumbs {
    font-size: 0.8125rem;
    color: hsl(0, 0%, 45%);
    display: flex;
    gap: 0.375rem;
  }
  .breadcrumbs a {
    color: hsl(5, 53%, 32%);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    text-decoration: underline;
  }
  .hero {
    margin: 1rem 0 1.5rem;
  }
  .kicker {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: hsl(5, 53%, 32%);
    font-weight: 600;
    margin: 0;
  }
  .hero h1 {
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    margin: 0.3rem 0 0.5rem;
  }
  .lede {
    color: hsl(0, 0%, 35%);
    margin: 0 0 0.75rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.8125rem;
    background-color: hsl(5, 53%, 32%);
    color: white;
  }
  .cta:hover {
    background-color: hsl(5, 53%, 26%);
  }
  .building-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.625rem;
  }
  .building-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem;
    border-radius: 0.75rem;
    background-color: white;
    border: 1px solid hsl(0, 0%, 90%);
    color: hsl(0, 0%, 15%);
    text-decoration: none;
  }
  .building-card:hover {
    border-color: hsl(5, 53%, 50%);
    transform: translateY(-1px);
  }
  .bname {
    font-weight: 700;
    color: hsl(0, 0%, 12%);
  }
  .bmeta {
    font-size: 0.75rem;
    color: hsl(0, 0%, 45%);
  }
  .bdesc {
    font-size: 0.8125rem;
    color: hsl(0, 0%, 30%);
    line-height: 1.4;
    margin-top: 0.2rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
